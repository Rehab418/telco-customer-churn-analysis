	measure 'Revenue At Risk' = ```
			
			        CALCULATE(
			            SUM(Telco_Churn[MonthlyCharges]),
			            Telco_Churn[Churn] = "No",
			            Telco_Churn[Contract] = "Month-to-month",
			            OR(
			                Telco_Churn[InternetService] = "Fiber optic",
			                Telco_Churn[PaymentMethod] = "Electronic check"
			            )
			        )
			```
		lineageTag: de65880f-bc52-41a2-9eab-64b0b954c870

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Comparison Label' = ```
			
			        VAR _period =
			            SELECTEDVALUE('Time Period Table'[Time Period])
			        RETURN
			        SWITCH(
			            _period,
			            "PM",  "vs Previous Month",
			            "3M",  "vs Previous 3 Months",
			            "6M",  "vs Previous 6 Months",
			            "12M", "vs Previous 12 Months",
			            "YTD", "vs Previous YTD"
			        )
			```
		lineageTag: 26ed2de2-c287-4332-adc6-410ec1557bb2

	measure 'Customers Start of Period' = ```
			
			        VAR _maxDate =
			            CALCULATE(MAX('Date'[Date]), REMOVEFILTERS('Date'))
			        RETURN
			        SWITCH(
			            SELECTEDVALUE('Time Period Table'[Time Period]),
			            "PM",  CALCULATE([Total Customers], PREVIOUSMONTH('Date'[Date])),
			            "3M",  CALCULATE([Total Customers], DATESINPERIOD('Date'[Date], EDATE(_maxDate, -3),  -3,  MONTH)),
			            "6M",  CALCULATE([Total Customers], DATESINPERIOD('Date'[Date], EDATE(_maxDate, -6),  -6,  MONTH)),
			            "12M", CALCULATE([Total Customers], DATESINPERIOD('Date'[Date], EDATE(_maxDate, -12), -12, MONTH)),
			            "YTD", CALCULATE([Total Customers], SAMEPERIODLASTYEAR(DATESYTD('Date'[Date])))
			        )
			```
		formatString: 0
		lineageTag: 298dfb9a-4c22-4236-a6e4-ae8c565e8253

	measure 'Total Customers Previous' = ```
			
			        VAR _period =
			            SELECTEDVALUE('Time Period Table'[Time Period])
			        VAR _maxDate =
			            CALCULATE(
			                MAX('Date'[Date]),
			                REMOVEFILTERS('Date')
			            )
			        RETURN
			        SWITCH(
			            _period,
			            "PM",
			                CALCULATE(
			                    [Total Customers],
			                    REMOVEFILTERS('Time Period Table'),
			                    DATESBETWEEN(
			                        'Date'[Date],
			                        EOMONTH(_maxDate, -2) + 1,
			                        EOMONTH(_maxDate, -1)
			                    )
			                ),
			            "3M",
			                CALCULATE(
			                    [Total Customers],
			                    REMOVEFILTERS('Time Period Table'),
			                    DATESINPERIOD('Date'[Date], EDATE(_maxDate, -3),  -3,  MONTH)
			                ),
			            "6M",
			                CALCULATE(
			                    [Total Customers],
			                    REMOVEFILTERS('Time Period Table'),
			                    DATESINPERIOD('Date'[Date], EDATE(_maxDate, -6),  -6,  MONTH)
			                ),
			            "12M",
			                CALCULATE(
			                    [Total Customers],
			                    REMOVEFILTERS('Time Period Table'),
			                    DATESINPERIOD('Date'[Date], EDATE(_maxDate, -12), -12, MONTH)
			                ),
			            "YTD",
			                CALCULATE(
			                    [Total Customers],
			                    REMOVEFILTERS('Time Period Table'),
			                    SAMEPERIODLASTYEAR(DATESYTD('Date'[Date]))
			                )
			        )
			```
		formatString: 0
		lineageTag: 78128796-d1e4-4be4-b11d-ad7be6595e8f

	measure 'Total Customers Var' = ```
			
			        [Total Customers] - [Total Customers Previous]
			```
		formatString: 0
		lineageTag: 2bb72f63-2ae9-4322-95a9-74f8d14b7f8b

	measure 'Total Customers % Change' = ```
			
			        DIVIDE(
			            [Total Customers] - [Total Customers Previous],
			            [Total Customers Previous]
			        )
			```
		lineageTag: 0aa096ef-cef0-4ee5-9b54-335ce91b6ed7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Customers Change Text' = ```
			
			        VAR pct        = [Total Customers % Change]
			        VAR diff       = [Total Customers Var]
			        VAR period     = SELECTEDVALUE('Time Period Table'[Time Period])
			        VAR periodText =
			            SWITCH(
			                period,
			                "PM",  "vs Last Month",
			                "3M",  "vs Last 3 Months",
			                "6M",  "vs Last 6 Months",
			                "12M", "vs Last 12 Months",
			                "YTD", "vs Previous YTD"
			            )
			        VAR pctText  = FORMAT(pct,  "+0.0%;-0.0%")
			        VAR diffText = FORMAT(diff, "+#,##0;-#,##0")
			        RETURN
			        pctText & " (" & diffText & ") " & periodText
			```
		lineageTag: d12429f9-16c1-4ddb-bb49-4a58d987b2fd

	measure 'Total Customers Color' = ```
			
			        SWITCH(
			            TRUE(),
			            [Total Customers % Change] > 0, "Green",
			            [Total Customers % Change] < 0, "Red",
			            "#808080"
			        )
			```
		lineageTag: 0dc82e08-d61f-4399-ac3d-daacb502ea4c

